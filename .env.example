# Configuración de ejemplo para TranscriptorIA
# Copia este archivo como .env y ajusta según necesites

# Puerto del servidor
FLASK_PORT=5000

# Modo debug (true/false)
FLASK_DEBUG=false

# Entorno (development/production)
FLASK_ENV=production

# Ruta de uploads (opcional)
# UPLOAD_DIR=/custom/path/audios/uploads

# Ruta de salidas (opcional)
# OUTPUT_DIR=/custom/path/salidas

# CORS - Orígenes permitidos (separados por comas)
# CORS_ORIGINS=https://mi-sitio.com,https://otro-sitio.com

# Límite de tamaño de archivo (bytes)
# MAX_FILE_SIZE=2147483648  # 2GB

# Timeout para uploads (segundos)
# UPLOAD_TIMEOUT=3600
